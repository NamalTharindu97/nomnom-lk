# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nomnom
DATABASE_PASSWORD=nomnom123
# DATABASE_PASSWORD_FILE=/run/secrets/database_password
DATABASE_NAME=nomnom
DATABASE_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_PASSWORD_FILE=/run/secrets/redis_password

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
# JWT_SECRET_FILE=/run/secrets/jwt_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# Browser dashboard sessions (must be true in production)
BROWSER_COOKIE_SECURE=false

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json

# R2 (Cloudflare R2 or MinIO)
R2_REGION=ap-southeast-1
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
# R2_ACCESS_KEY_FILE=/run/secrets/r2_access_key
# R2_SECRET_KEY_FILE=/run/secrets/r2_secret_key
R2_BUCKET=nomnom-images
R2_ENDPOINT=http://localhost:9000  # MinIO endpoint for dev
R2_FORCE_PATH_STYLE=true

# Sentry
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin
ADMIN_EMAIL=admin@nomnom.lk
ADMIN_PASSWORD=
# ADMIN_PASSWORD_FILE=/run/secrets/admin_password

# SMTP (optional; use the file form for a production password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_PASSWORD_FILE=/run/secrets/smtp_password
SMTP_FROM=NomNom LK <noreply@nomnom.lk>
