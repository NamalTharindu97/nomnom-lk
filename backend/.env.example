# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENVIRONMENT=development

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nomnom
DATABASE_PASSWORD=nomnom123
DATABASE_NAME=nomnom
DATABASE_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# Firebase
FIREBASE_CREDENTIALS_PATH=./config/firebase-credentials.json

# R2 (Cloudflare R2 or MinIO)
R2_REGION=ap-southeast-1
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=nomnom-images
R2_ENDPOINT=http://localhost:9000  # MinIO endpoint for dev
R2_FORCE_PATH_STYLE=true

# Sentry
SENTRY_DSN=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin
ADMIN_EMAIL=admin@nomnom.lk
ADMIN_PASSWORD=Admin@123
