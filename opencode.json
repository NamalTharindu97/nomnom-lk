{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "models": {
        "big-pickle": {
          "variants": {
            "fast": {
              "reasoningEffort": "low"
            },
            "balanced": {
              "reasoningEffort": "medium"
            },
            "thorough": {
              "reasoningEffort": "high"
            }
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "variant": "balanced"
    },
    "plan": {
      "variant": "thorough"
    }
  },
  "skills": {
    "paths": [".agents/skills"]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  }
}
